# Copy this to .env and fill in real values before running docker compose.
# .env is gitignored — never commit secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# Repo to index (absolute path on the host)
REPO_PATH=/path/to/your/repo

# Postgres credentials (used by the embedding store)
POSTGRES_USER=cih
POSTGRES_PASSWORD=changeme

# ── Optional — Security ───────────────────────────────────────────────────────

# Protect /mcp and /graph with a static bearer token.
# Unset = open access (dev mode only). Set in production.
# CIH_API_TOKEN=your-secret-token-here

# Note: the server no longer runs an LLM agent. Natural-language Q&A lives in your
# MCP client (Claude Code, etc.), which drives CIH's deterministic tools. There is
# no CIH_AGENT_* / LLM key to configure here.

# ── Optional — Naming ─────────────────────────────────────────────────────────

# Graph key used in FalkorDB (default: cih). Change if running multiple repos.
# CIH_GRAPH_KEY=my-repo

# Repo name shown in the docs-viewer URL prefix
# REPO_NAME=my-repo

# ── Optional — Postgres naming ────────────────────────────────────────────────
# POSTGRES_DB=cih
